# Copy to .env and fill in.  Do NOT commit .env (it is gitignored).
# Korea (OpenDART) — required for kr companies.  Free key: https://opendart.fss.or.kr
DART_KEY=
# Japan (EDINET) — annual securities-report data.  Free key: https://api.edinet-fsa.go.jp
EDINET_KEY=
# Japan (J-Quants V2) — recent ~2yr quarterly data (fills EDINET's post-2024 gap).
# Free API key from the dashboard: https://jpx-jquants.com  (sent as x-api-key)
JQUANTS_KEY=
# Taiwan (FinMind) — optional; raises rate limits.  https://finmindtrade.com
FINMIND_TOKEN=
# US (SEC EDGAR) — no key, but SEC asks for an identifying User-Agent.
SEC_USER_AGENT=earnings-verify your-email@example.com
